# Cliente: URL do projeto + chave anon (public), em Project Settings → API.
# NÃO use service_role / Secret keys no front-end (quebra RLS e expõe o projeto).
#
# Se aparecer "Invalid schema: fichas_jogador": no painel, Data API → Exposed schemas,
# adicione "fichas_jogador"; depois rode database/expose_api_schema_fichas_jogador.sql
#
# Opção A — duas linhas:
# SUPABASE_URL=https://abcdxyz.supabase.co
# ANON_KEY=eyJhbGciOi...
# (ou SUPABASE_ANON_KEY=... — mesmo efeito)
#
# Opção B — uma linha (URL ou postgres + | + anon):
# SUPABASE_URL=https://abcdxyz.supabase.co|eyJhbGciOi...
#
# Postgres + anon em linhas separadas:
# SUPABASE_URL=postgresql://postgres:SENHA@db.abcdxyz.supabase.co:5432/postgres
# ANON_KEY=eyJhbGciOi...

SUPABASE_URL=
ANON_KEY=
